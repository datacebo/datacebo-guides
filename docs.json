{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DataCebo Guides",
  "colors": {
    "primary": "#03AFF1",
    "light": "#03AFF1",
    "dark": "#0690D1"
  },
  "favicon": "/logo/DataCebo_brandmark_color_July 31 2025.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open",
          "href": "https://docs.sdv.dev/sdv/"
        },
        {
          "anchor": "Blog",
          "icon": "blog",
          "href": "https://datacebo.com/blog/"
        }
      ]
    },
    "tabs": [
      {
        "tab": "SDV",
        "groups": [
          {
            "group": "Synthetic data",
            "pages": [
              "core-concepts/synthetic-data"
            ]
          },
          {
            "group": "Enterprise",
            "pages": [
              "enterprise/enterprise-data",
              "enterprise/platform-needs"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "core-concepts/constraints"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/datacebo-horizontal-logo-black.svg",
    "dark": "/logo/datacebo-horizontal-logo-white.svg"
  },
  "ui": {
    "show_sidebar": true,
    "show_breadcrumbs": false,
    "show_outline": true,
    "show_next_prev": false
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "enabled": false,
    "socials": {
      "x": "https://x.com/datacebo?lang=en",
      "github": "https://github.com/datacebo",
      "linkedin": "https://www.linkedin.com/company/datacebo/"
    }
  }
}